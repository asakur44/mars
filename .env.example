# Copy to .env and fill in your keys. .env is gitignored.
# Or, more commonly, set these via `claude mcp add --env KEY=VAL` instead.

# Required for ask_deepseek
DEEPSEEK_API_KEY=sk-...

# Required for ask_openrouter
OPENROUTER_API_KEY=sk-or-v1-...

# Required for ask_grok
XAI_API_KEY=xai-...

# Required for ask_zai (legacy "id.secret" format; JWT generated per call)
ZAI_API_KEY=...

# Required for ask_mimo (Xiaomi MiMo Singapore plan)
MIMO_API_KEY=...

# Required for ask_kimi (Moonshot Open Platform, api.moonshot.ai)
KIMI_API_KEY=sk-...
# Optional: only for ask_kimi with model="kimi-for-coding" (Kimi Code
# subscription endpoint, api.kimi.com/coding). Leave unset otherwise.
# KIMI_CODE_API_KEY=

# Optional: where to store DeepSeek/OpenRouter/Grok/Z.AI session JSON files.
# Default: ~/.mars/  (with ~/.modelmesh/ used as a deprecated fallback if
# it exists and ~/.mars/ doesn't yet — `mv ~/.modelmesh ~/.mars` to silence
# the warning). Legacy MODELMESH_DIR env var also accepted with a
# DeprecationWarning; removed in MARS v0.2.0.
# MARS_DIR=/custom/path

# Optional: OpenRouter analytics attribution headers.
# OPENROUTER_REFERER=https://github.com/your-username/your-project
# OPENROUTER_TITLE=my-project
