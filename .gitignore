# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
*.whl

# Virtual envs
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# Tooling
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.uv-cache/

# IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local user state — never commit session files; they may contain prompts/responses
.mars/
.modelmesh/  # legacy path; kept for safety while existing users migrate to ~/.mars/
api-sessions/

# Secrets — never commit real keys
secrets.json
*.key
*.pem
setup.bat              # local setup scripts often hardcode real API keys
*_probe.py             # local probe/scratch scripts may embed client secrets
*-auth.json            # cached OAuth refresh tokens (e.g. antigravity-auth.json)
